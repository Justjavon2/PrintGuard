# Create a new file named .env and replace with correct info
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Optional alias used by some Supabase setup guides:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key

# Email provider for notification sends: smtp | resend
EMAIL_PROVIDER=smtp

# SMTP configuration (required when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=alerts@printguard.local
SMTP_USE_TLS=true
NOTIFICATION_EMAIL_RETRY_ATTEMPTS=3
NOTIFICATION_GUARD_START_COOLDOWN_SECONDS=600

# Resend configuration (required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=alerts@yourdomain.com
