# The URL of your FastAPI backend (you can change this if needed)
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# Supabase URL
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Preferred key variable in this project
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<your-publishable-or-anon-key>"

# Optional alias from some Supabase setup flows
# If NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is set, it takes precedence.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="<your-publishable-or-anon-key>"
